<h1 class="mb-2">Services</h1>

<p class="text-muted mb-4" style="font-size: var(--text-base);">Applications and APIs for data discovery, transformation, and integration.</p>

<div class="row g-3">
  {% for item in services %}
  <div class="col-md-4">
    <div {% if item.coming_soon %}class="app-card app-card-coming-soon"{% else %}onclick="if(!event.target.closest('a')){ window.open('{{ item.url }}', '_blank'); }" class="app-card" style="cursor: pointer;"{% endif %}>
      <div class="app-card-header">
        <div class="d-flex align-items-center gap-3">
          <div class="app-card-icon">
            <i class="bi {{ item.icon }}"></i>
          </div>
          <div class="app-card-name">
            {{ item.name }}
          </div>
        </div>
        <div class="d-flex align-items-center gap-3">
          {% if not item.coming_soon %}
            {% if item.github %}
              <a href="{{ item.github }}" target="_blank" rel="noopener noreferrer" class="app-card-action-link" title="GitHub Repository">
                <i class="bi bi-github"></i>
              </a>
            {% endif %}
            <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="app-card-action-link" title="Visit Service">
              <i class="bi bi-arrow-up-right"></i>
            </a>
          {% else %}
            <span class="badge bg-secondary badge-coming-soon" style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em; padding: 4px 8px; background-color: rgba(255, 255, 255, 0.15) !important; color: var(--color-text-secondary) !important; border: 1px solid rgba(255, 255, 255, 0.2);">Coming Soon</span>
          {% endif %}
        </div>
      </div>
      <div class="app-card-desc">{{ item.description | markdown | safe }}</div>
      <div class="app-card-tags">
        {% for tag in item.tags %}
          <span class="app-card-tag">{{ tag }}</span>
        {% endfor %}
      </div>
    </div>
  </div>
  {% endfor %}
</div>
